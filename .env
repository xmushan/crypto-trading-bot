
# 自动执行交易开关 / Auto-execution switch ⚠️⚠️⚠️ 危险 / Dangerous
# 调试好之后就可以设置成 true 开启自动交易了
# After debugging, set to true to enable auto trading
AUTO_EXECUTE=true


# LLM 提供商 / LLM Provider
# 可选值 / Options: openai, anthropic, google, ollama
LLM_PROVIDER=openai

# 深度思考模型 / Deep thinking model
DEEP_THINK_LLM=deepseek-reasoner

# 快速思考模型 / Quick thinking model
QUICK_THINK_LLM=deepseek-chat

# LLM API 后端地址 / LLM API backend URL
# 说明 / Description: 如果使用 OpenAI 兼容 API，修改此项
LLM_BACKEND_URL=https://api.deepseek.com

# OpenAI API 密钥 / OpenAI API Key ⚠️ 必需 / Required
OPENAI_API_KEY=OPENAI_API_KEY

# 交易策略 Prompt 文件路径 / Trading strategy prompt file path
# TRADER_PROMPT_PATH=prompts/trader_json_no_trailing_stop.txt
TRADER_PROMPT_PATH=TRADER_PROMPT_PATH

# 币安 API 密钥 / Binance API Key ⚠️ 实盘交易必需 / Required for live trading
BINANCE_API_KEY=BINANCE_API_KEY
BINANCE_API_SECRET=BINANCE_API_SECRET



# 币安代理地址 / Binance Proxy (可选 / Optional)
# 说明 / Description: 如果无法直接访问币安，需要设置代理
BINANCE_PROXY=

# 币安杠杆倍数 / Binance Leverage
# 格式 / Format:
#   - 固定杠杆 / Fixed leverage: 单个数字，如 "10"
#   - 动态杠杆 / Dynamic leverage: 范围格式，如 "10-20" ⭐ 新功能
BINANCE_LEVERAGE=BINANCE_LEVERAGE

# 测试模式开关 / Test Mode ✅ 使用币安测试网进行交易（推荐先使用测试网验证策略）
# 说明 / Description:
#   - true:  连接币安测试网 (testnet.binancefuture.com)，使用虚拟资金交易
#   - false: 连接币安实盘网 (fapi.binance.com)，使用真实资金交易 ⚠️ 谨慎！
# 测试网 API 密钥获取 / Get testnet API keys:
#   https://testnet.binancefuture.com/
# 注意 / Note: 测试网和实盘网使用不同的 API 密钥，需要分别申请
BINANCE_TEST_MODE=true

# 持仓模式 / Position Mode ⚠️⚠️优先使用单向持仓模式！！！双向持仓模式目前有 BUG
# 可选值 / Options: oneway, hedge, auto
# 说明 / Description:
#   - oneway: 单向持仓模式，只能持有多仓或空仓其中之一 / One-way mode, long or short only
#   - hedge: 双向持仓模式，可同时持有多仓和空仓 / Hedge mode, can hold both long and short
#   - auto: 自动检测（推荐）/ Auto-detect (recommended)
BINANCE_POSITION_MODE=oneway

# 交易对列表 / Trading Pairs ⭐ 支持单个或多个
# 建议 / Recommendation: 不要超过 3 个交易对，避免过度分散资金
# 示例使用 / Example usage:
CRYPTO_SYMBOLS=CRYPTO_SYMBOLS

# K线时间周期 / Candlestick timeframe
# 可选值 / Options: 3m, 15m, 1h, 4h, 1d
# 说明 / Description:
#   - 3m: 极短线，超高频交易（默认）/ Extreme short term, ultra-high frequency (default)
#   - 15m: 超短线，高频交易（仅供经验丰富者）/ Ultra-short term, high frequency
#   - 1h: 短线，日内交易（推荐）/ Short term, day trading (recommended)
#   - 4h: 中短线 / Medium-short term
#   - 1d: 长线，波段交易 / Long term, swing trading
# 用途 / Purpose: 决定从币安获取的K线数据间隔，用于计算技术指标（EMA、MACD、RSI等）
# 默认值 / Default: 3m
CRYPTO_TIMEFRAME=CRYPTO_TIMEFRAME

# 系统运行间隔 / System Execution Interval ⭐ 独立配置 / Independent Setting
# 可选值 / Options: 3m, 15m, 1h, 4h, 1d（与 K线时间周期格式相同）
# 说明 / Description:
#   - 决定系统多久运行一次分析和交易决策
#     Determines how often the system runs analysis and trading decisions
#   - 如果不设置，默认使用 CRYPTO_TIMEFRAME 的值
#     If not set, defaults to CRYPTO_TIMEFRAME value
# 使用场景 / Use Cases:
#   场景1：K线间隔 = 运行间隔（标准模式）
#   Case 1: K-line interval = Execution interval (Standard mode)
#     CRYPTO_TIMEFRAME=15m
#     TRADING_INTERVAL=15m（或不设置 / or leave empty）
#     效果：每15分钟获取15分钟K线数据，并运行一次分析
#     Result: Fetch 15m candles every 15 minutes and run analysis
#
#   场景2：K线间隔 < 运行间隔（快速K线 + 低频决策）⭐ 推荐 / Recommended
#   Case 2: K-line interval < Execution interval (Fast candles + Low-frequency decisions)
#     CRYPTO_TIMEFRAME=3m（获取3分钟精细数据 / Fetch 3m fine-grained data）
#     TRADING_INTERVAL=15m（每15分钟运行一次 / Run analysis every 15 minutes）
#     效果：基于3分钟K线计算指标，但每15分钟才做决策
#     Result: Calculate indicators from 3m candles, but make decisions every 15 minutes
#     好处：更精细的技术指标，但避免过度交易
#     Benefits: More precise technical indicators while avoiding overtrading
#
#   场景3：K线间隔 > 运行间隔（不推荐，会导致数据重复）
#   Case 3: K-line interval > Execution interval (Not recommended, causes data duplication)
#     CRYPTO_TIMEFRAME=1h
#     TRADING_INTERVAL=15m
#     问题：每15分钟运行但1小时K线未更新，浪费API调用
#     Issue: Run every 15 min but 1h candles don't update, wasting API calls
#
# 建议 / Recommendation:
#   - 快速K线 + 低频决策：CRYPTO_TIMEFRAME=3m, TRADING_INTERVAL=15m（推荐 / Recommended）
#   - 标准模式：CRYPTO_TIMEFRAME=15m, TRADING_INTERVAL=15m
#   - 长线交易：CRYPTO_TIMEFRAME=1h, TRADING_INTERVAL=1h
# 默认值 / Default: 与 CRYPTO_TIMEFRAME 相同 / Same as CRYPTO_TIMEFRAME
TRADING_INTERVAL=15m

# 数据回看天数 / Lookback days (可选 / Optional)
# 说明 / Description: 获取历史 K 线数据的天数，用于计算技术指标
# 智能推荐 / Smart recommendation (如果不设置，系统会自动根据时间周期选择):
# 影响 / Impact:
#   - 天数越多，数据越全面，但会增加 LLM context 负担
#   - 天数越少，分析速度快，但可能遗漏长期趋势
# 格式 / Format: 正整数（天数）/ Positive integer (days)
CRYPTO_LOOKBACK_DAYS=3


# 是否启用多时间周期分析 / Enable multi-timeframe analysis
ENABLE_MULTI_TIMEFRAME=true

# 更长期的时间周期 / Longer timeframe (可选 / Optional)
# 可选值 / Options: 1h, 4h, 1d
# 默认值 / Default: 4h
CRYPTO_LONGER_TIMEFRAME=1h

# 是否启用市场情绪分析（CoinMarketCap 恐惧和贪婪指数）
# Enable market sentiment analysis (CoinMarketCap Fear and Greed Index)
# 格式 / Format: true 或 false / true or false
# 说明 / Description:
#   - 使用 CoinMarketCap 的加密货币恐惧和贪婪指数（0-100）
#   - Uses CoinMarketCap's Crypto Fear and Greed Index (0-100)
#   - 指数越高表示市场越贪婪，指数越低表示市场越恐惧
#   - Higher values indicate greed, lower values indicate fear
#   - 这是市场级别的指标，不针对特定币种
#   - This is a market-wide indicator, not symbol-specific
# 网络配置 / Network Configuration:
#   - 自动复用 BINANCE_PROXY 和 BINANCE_PROXY_INSECURE_SKIP_TLS 配置
#   - Automatically reuses BINANCE_PROXY and BINANCE_PROXY_INSECURE_SKIP_TLS settings
#   - 如果你在国内，需要配置代理才能访问 CoinMarketCap API
#   - If you're in China, you need to configure a proxy to access CoinMarketCap API
# API Key 配置 / API Key Configuration:
#   - 默认使用内置的 API Key（internal/dataflows/sentiment.go）
#   - Default uses built-in API Key (internal/dataflows/sentiment.go)
#   - 如需使用自己的 API Key，请修改源代码中的 coinMarketCapAPIKey 常量
#   - To use your own API Key, modify the coinMarketCapAPIKey constant in the source code
ENABLE_SENTIMENT_ANALYSIS=false

# 是否启用止损管理 / Enable stop-loss management
# 可选值 / Options: true, false
# 说明 / Description:
#   - true: 启用自动止损管理（强烈推荐）/ Enable auto stop-loss (highly recommended)
#   - false: 禁用止损（危险！仅用于测试）/ Disable stop-loss (dangerous! testing only)
# 警告 / Warning: 禁用止损会导致无限亏损风险！
# 默认值 / Default: true
ENABLE_STOPLOSS=true

STOPLOSS_SCOPE_THRESHOLD=0.3

# 追踪止损的 ATR 周期 / ATR period for trailing stop
# 说明 / Description:
#   - 追踪止损使用长期时间周期（CRYPTO_LONGER_TIMEFRAME，如 4h）的 ATR 数据
#   - The trailing stop uses ATR data from longer timeframe (CRYPTO_LONGER_TIMEFRAME, e.g., 4h)
#   - ATR 周期决定波动率的计算窗口，影响止损距离
#   - ATR period determines volatility calculation window, affecting stop distance
# 可选值 / Options:
#   - 3:  短期灵敏，快速跟随价格，但可能被噪音触发
#   - 7:  平衡选择，兼顾灵敏度和稳定性（推荐）/ Balanced choice (recommended)
#   - 14: Wilder 标准周期，更平滑，适合中长线趋势跟踪
# 默认值 / Default: 7
TRAILING_STOP_ATR_PERIOD=7

# ==================== 追踪止损配置 / Trailing Stop Configuration ====================

# ✨ 本地追踪止损（已启用，无需 LLM 计算）
# ✨ Local Trailing Stop (Enabled, No LLM Calculation Needed)
#
# 系统已实现本地化追踪止损管理器，使用确定性公式自动计算追踪止损价格，无需依赖 LLM。
# The system now has a local trailing stop manager that automatically calculates trailing stop
# prices using deterministic formulas, without relying on LLM.
#
# 追踪止损公式 / Trailing Stop Formula:
#   - 多仓 / Long:  新止损价 = 持仓以来最高价 - 2.5 × ATR(来自长期时间周期，周期可配置)
#   - 空仓 / Short: 新止损价 = 持仓以来最低价 + 2.5 × ATR(来自长期时间周期，周期可配置)
#   - ATR 来源：CRYPTO_LONGER_TIMEFRAME 的数据（如 4h），周期由 TRAILING_STOP_ATR_PERIOD 指定
#
# 优势 / Benefits:
#   ✅ 稳定性：100% 确定性计算，无 LLM 输出不一致问题
#   ✅ 成本：减少 LLM API 调用，降低运营成本
#   ✅ 实时性：每个交易间隔（如 5 分钟）自动更新
#   ✅ 定制化：支持不同币种配置不同参数（在代码中配置）
#
# 配置位置 / Configuration Location:
#   不同币种的追踪止损参数在代码中配置（无需修改 .env）
#   Trailing stop parameters for different symbols are configured in code (no .env changes needed)
#   文件 / File: internal/executors/trailing_stop_calculator.go
#
# 可调参数（在代码中）/ Adjustable Parameters (in code):
#   - InitialATRPeriod:      初始止损的 ATR 周期（默认 14 - 标准 Wilder 周期）/ Initial stop ATR period (default 14 - Wilder's standard)
#   - InitialATRMultiplier:  初始止损的 ATR 倍数（默认 2.5）/ Initial stop ATR multiplier (default 2.5)
#   - TrailingATRPeriod:     追踪止损的 ATR 周期（默认 14 - 标准 Wilder 周期）/ Trailing stop ATR period (default 14 - Wilder's standard)
#   - TrailingATRMultiplier: 追踪止损的 ATR 倍数（默认 2.5）/ Trailing stop ATR multiplier (default 2.5)
#   - UpdateThreshold:       更新阈值百分比（默认 0.2%）/ Update threshold percentage (default 0.2%)
#   - MinStopDistance:       最小止损距离（默认 0.5%）/ Min stop distance (default 0.5%)
#   - MaxStopDistance:       最大止损距离（默认 5.0%）/ Max stop distance (default 5.0%)
#
# 示例配置（代码中）/ Example Configuration (in code):
#   BTC/ETH:  ATR倍数 2.0, 阈值 1.0%, 距离范围 1.5%-6.0%
#   SOL/XRP:  ATR倍数 2.2, 阈值 1.2%, 距离范围 2.0%-8.0%（波动较大币种）
#
# 注意 / Notes:
#   - 系统会在每个交易间隔自动检查并更新追踪止损
#   - 止损价格只会朝有利方向移动（多仓向上，空仓向下）
#   - 变化幅度低于阈值时跳过更新，避免频繁调整
#   - The system automatically checks and updates trailing stops every trading interval
#   - Stop prices only move in favorable direction (up for long, down for short)
#   - Updates are skipped if change is below threshold to avoid frequent adjustments

# 调试模式 / Debug mode
DEBUG_MODE=false

# 选择的分析师 / Selected analysts
# 说明 / Description: 目前 Go 版本使用固定的分析师组合，此选项暂不生效
# 固定组合 / Fixed combination: market, crypto, sentiment, position
# 默认值 / Default: market,crypto,sentiment
SELECTED_ANALYSTS=market,crypto,sentiment



# Web 监控配置（可选）
# Web Monitoring Configuration (Optional)

# Web 端口 / Web Port
# 默认值 / Default: 8080
WEB_PORT=8080

# Web 登录认证 / Web Login Authentication ⚠️ 重要 / Important
# 说明 / Description:
#   由于 Web 界面包含敏感交易信息，强烈建议设置安全的用户名和密码
#   The web interface contains sensitive trading information, strongly recommend setting secure credentials
# 安全建议 / Security Recommendations:
#   1. 使用强密码（至少 12 位，包含大小写字母、数字和特殊字符）
#      Use strong password (at least 12 characters, mix of uppercase, lowercase, numbers, special chars)
#   2. 不要使用默认密码 "changeme"
#      Do not use the default password "changeme"
#   3. 定期更换密码
#      Change password regularly
#   4. 如果使用反向代理（如 Nginx/Caddy），可以在代理层配置认证
#      If using reverse proxy (Nginx/Caddy), you can configure auth at proxy level
# 格式 / Format: 字符串 / String
WEB_USERNAME=WEB_USERNAME
WEB_PASSWORD=WEB_PASSWORD

